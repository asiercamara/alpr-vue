# Exigir la versión de Node declarada en package.json (campo "engines")
engine-strict=true

# Tratar problemas de peerDependencies como error
strict-peer-dependencies=true

# Bloquear scripts de postinstall de dependencias por defecto
# Los paquetes permitidos se definen en package.json > pnpm.allowedDeprecatedVersions
# y pnpm.allowBuilds
ignore-dep-scripts=true
