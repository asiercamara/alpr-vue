{
  "name": "alpr-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && tsc -p tsconfig.workers.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "prepare": "husky",
    "dev:docs": "vitepress dev docs",
    "build:docs": "vitepress build docs",
    "build:all": "pnpm build && pnpm build:docs",
    "preview:docs": "vitepress preview docs",
    "deploy:surge": "bash ./scripts/deploy-surge.sh",
    "security:audit": "pnpm audit --audit-level high",
    "security:audit:ci": "pnpm audit --audit-level high --prod"
  },
  "dependencies": {
    "onnxruntime-web": "^1.24.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=8.0.5",
      "vitepress>vite": "^5.4 || ^6.0",
      "protobufjs": ">=7.5.5"
    }
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": "prettier --write"
  }
}
